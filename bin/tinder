    ],
    "log": ["", "test"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test2"],
    "tmr": ["", "22:00 test"]
}

post = {
    "dbg": [""],
    "dne": [""," mekker"],
    "exp": [""],
    "rem": ["", "rem hnrss"]
}


if __name__ == "__main__":
    Runs.wrap(main, dofinal=final)
