#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from nixt.defines import Boot, Main, Message, Method, Mods
from nixt.defines import Parse, Time, Workdir


Workdir.wdr = ".test"
Mods.dir("mods", "mods")


class Vars:

    nrevents = 0
    starttime = 0


def raw(text):
    if "v" in Main.opts:
        print(text.encode('utf-8', 'replace').decode("utf-8"))
        sys.stdout.flush()


def payload(todo):
    for cmd, example in todo.items():
        for ex in example:
            Vars.nrevents += 1
            evt = Message()
            evt.text = f"{cmd} {ex}"
            Mods.command(evt)
            for text in evt.result:
                raw(text)


def final():
    if "v" not in Main.opts:
        return
    total = Vars.nrevents
    endtime = time.time()
    lap = Time.elapsed(endtime-Vars.starttime)
    percall = (endtime-Vars.starttime)/total
    print(f"{Method.fmt(Main, skip='otxt,txt')}")
    print(f"events: {total}")
    print(f"total: {lap} nrs: {Vars.nrevents} call: %.6fs" % percall)
    print(threading.enumerate())


def main():
    Parse.parse(Main, " ".join(sys.argv[1:]))
    Mods.configure()
    Mods.scanner()
    if os.path.exists(Workdir.wdr):
        shutil.rmtree(Workdir.wdr)
    Vars.starttime = time.time()
    nrs = Main.index or 1
    for _x in range(nrs):
        payload(pre)
    for _x in range(nrs):
        payload(examples)
    for _x in range(nrs):
        payload(post)


examples = {
    "cmd": [""],
    "dis": [""],
    "dpl": ["", "tittle.link"],
    "eml": ["", "root@localhost"],
    "flt": ["", "0"],
    "fnd": ["", "log", "todo"],
    "fie": ["", "log", "todo"],
    "lou": [""],
    "mbx": ["", "~/25-1-2013"],
    "man": ["", "nixt nixtniet@gmail.com Nixt Niet"],
    "nme": ["", "hnrss hn"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "tbl": [""],
    'thr': [""],
    'upt': [""],
    'ver': [""],
}


pre = {
    "cfg": [
        '',
        'main',
        'irc',
        'rss',
        'rst',
        'udp',
        'web',
        'main nick=mekker',
        'irc nick=mekker',
        'rss nick=mekker',
        'rst nick=mekker',
        'udp nick=mekker',
        'web nick=mekker'
    ],
    "imp": [
        "",
        "testing/opml/feeds.opml",
    ],
    "log": ["", "test"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test2"],
    "tmr": ["", "22:00 test"]
}

post = {
    "dbg": [""],
    "dne": ["", "mekker"],
    "exp": [""],
    "rem": ["", "rem hnrss"]
}


if __name__ == "__main__":
    Boot.wrap(main, dofinal=final)
