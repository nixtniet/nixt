#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from nixt.defines import Boot, Buffered, Commands, Log, Main, Message
from nixt.defines import Mods, Object, Parse, Thread, Time, Workdir, e


Main.debug = True
Main.threaded = True
Main.wdr = ".test"
Main.user = True
Mods.add("mods", "mods")
Mods.add("other", "other")
Workdir.wdr = Main.wdr
Log.level("debug")


class CLI(Buffered):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))
            sys.stdout.flush()


class Clients:

    clients = []
    lock = threading.RLock()
    last = 0
    nrevents = 0
    nrcpu = 1

    @classmethod
    def add(cls, client):
        cls.clients.append(client)

    @classmethod
    def init(cls, client):
        with cls.lock:
            cls.nrcpu = os.cpu_count()
            for _x in range(Clients.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1
            cls.nrevents += 1

    @classmethod
    def shutdown(cls):
        for client in cls.clients[::-1]:
            client.wait()
            client.stop()


class Run:

    nrs = 0

    @staticmethod
    def check(opts):
        "check for command line options."
        for arg in sys.argv:
            if not arg.startswith("-"):
                continue
            for opt in opts:
                if opt in arg:
                    return True
        return False

    @staticmethod
    def payload(todo):
        for cmd, example in todo.items():
            for ex in example:
                evt = Message()
                evt.kind = "command"
                evt.text = f"{cmd} {ex}"
                Clients.put(evt)


def final():
    total = Clients.nrevents
    endtime = time.time()
    lap = Time.elapsed(endtime-Time.starttime)
    percall = (endtime-Time.starttime)/total
    if Main.verbose:
        print(f"{Object.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {Clients.nrcpu} events: {total}")
        print(f"total: {lap} nrs: {Clients.nrevents - total} call: %.6fs" % percall)
        res = ""
        for client in Clients.clients:
            res += str(client.queue.qsize()) + " "
        print(res.strip())
        print(threading.enumerate())


def main():
    if e(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Run.check("v"):
        Main.verbose = True
    Parse.parse(Main, " ".join(sys.argv[1:]))
    Boot.scanner()
    Clients.init(CLI)
    Run.nrs = Main.index or 1
    thrs = []
    for _x in range(Run.nrs):
        thrs.append(Thread.launch(Run.payload, pre, daemon=True))
    for thr in thrs:
        thr.join()
    thrs = []
    for _x in range(Run.nrs):
        thrs.append(Thread.launch(Run.payload, examples, daemon=True))
    for thr in thrs:
        thr.join()
    thrs = []
    for _x in range(Run.nrs):
        thrs.append(Thread.launch(Run.payload, post, daemon=True))
    for thr in thrs:
        thr.join()
    Clients.shutdown()
    while 1:
        if len(threading.enumerate()) == 1:
            break
        time.sleep(0.01)


examples = {
    "cmd": [""],
    "dis": [""],
    "dne": ["", "bla"],
    "dpl": ["hnrss title,url", ""],
    "eml": ["", "root@localhost"],
    "fie": ["", "log", "todo"],
    "flt": ["", "0"],
    "fnd": ["", "log", "rss", "config", "todo", 'timers'],
    "lou": [""],
    "man": ["", "genocide nixtniet@gmail.com Nixt Niet"],
    "mbx": [""],
    "mod": [""],
    "mre": [""],
    "nme": ["", "hnrss hackernews"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "thr": [""],
    "upt": [""],
    "wsd": [""]
}


pre = {
    "cfg": [
        '',
        'main',
        'irc',
        'rss',
        'rst',
        'udp',
        'web',
        'main nick=mekker',
        'irc nick=mekker',
        'rss nick=mekker',
        'rst nick=mekker',
        'udp nick=mekker',
        'web nick=mekker'
    ],
    "imp": [
        "",
        "testing/opml/feeds.opml",
    ],
    "log": ["", "test"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test2"],
    "tmr": ["", "22:00 test"],
}

post = {
    "dbg": [""],
    "dne": ["", "mekker"],
    "exp": [""],
    "rem": ["", "hnrss"]
}


if __name__ == "__main__":
    Boot.wrap(main, final=final)
