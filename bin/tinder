#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from nixt.face import Boot, Client, Commands, Event, Main, Object
from nixt.face import Mods, Parse, Thread, Time, Workdir, e


Main.debug = True
Main.threaded = True
Main.wdr = ".test"
Main.user = True


Workdir.wdr = Main.wdr


Mods.add("mods", "mods")
Mods.add("other", "other")


class CLI(Client):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))
            sys.stdout.flush()


class Clients:

    clients = []
    lock = threading.RLock()
    last = 0
    nrevents = 0
    nrcpu = 1

    @classmethod
    def add(cls, client):
        cls.clients.append(client)

    @classmethod
    def init(cls, client):
        with cls.lock:
            cls.nrcpu = os.cpu_count()
            for _x in range(Clients.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1
            cls.nrevents += 1

    @classmethod
    def shutdown(cls):
        for client in cls.clients:
            client.wait()
        for client in cls.clients:
            client.stop()


class Run:

    arguments = [
                 "main",
                 "log",
                 "rss",
                 "config",
                 "todo",
                 'timers',
                 'hnrss title,link',
                 "nick=mekker",
                 "http://hnrss.org/newest",
                 "22:00 test",
                 "nixt nixtniet@gmail.com Nixt Niet"
                ]

    @staticmethod
    def check(opts):
        "check for command line options."
        for arg in sys.argv:
            if not arg.startswith("-"):
                continue
            for opt in opts:
                if opt in arg:
                    return True
        return False

    @staticmethod
    def payload():
        for cmd in Commands.commands():
            for arg in Run.arguments:
                evt = Event()
                evt.kind = "command"
                evt.text = f"{cmd} {arg}"
                Clients.put(evt)


def main():
    if e(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Run.check("v"):
        Main.verbose = True
    Parse.parse(Main, " ".join(sys.argv[1:]))
    Boot.scanner()
    Clients.init(CLI)
    nrs = Main.index or 1
    thrs = []
    for _x in range(nrs):
        thrs.append(Thread.launch(Run.payload))
    for thr in thrs:
        thr.join()
    Clients.shutdown()
    total = len(Commands.commands()) * len(Run.arguments) * nrs
    endtime = time.time()
    lap = Time.elapsed(endtime-Time.starttime)
    percall = (endtime-Time.starttime)/total
    while 1:
        if len(threading.enumerate()) == 1:
            break
    if Main.verbose:
        print(f"{Object.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {Clients.nrcpu} events: {total}")
        print(f"total: {lap} nrs: {Clients.nrevents - total} call: %.6fs" % percall)
        print(threading.enumerate())


if __name__ == "__main__":
    Boot.wrap(main)
