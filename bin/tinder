"stress test"


import logging
import os
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from bot.defines import Boot, Buffer, Commands, Engine, Logging, Main, Message, Mods
from bot.defines import Object, Parse, Task, Thread, Time, Utils, Workdir, e


Main.debug = True
Main.name = "tinder"
Main.wdr = ".test"
Main.user = True


Task.bork = True
Workdir.wdr = Main.wdr


Mods.add("modules", Utils.moddir())
Mods.add("mods", "mods")
Mods.add("other", "other")


Logging.level("debug")
Boot.scanner()


class CLI(Engine, Buffer):

    def __init__(self):
        Buffer.__init__(self)
        Engine.__init__(self)
        self.register("command", Commands.command)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))
            sys.stdout.flush()


class Clients:

    clients = []
    lock = threading.RLock()
    last = 0
    nrevents = 0
    nrcpu = 1

    @classmethod
    def add(cls, client):
        cls.clients.append(client)

    @classmethod
    def init(cls, nr, client):
        with cls.lock:
            cls.nrcpu = nr
            for _x in range(Clients.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        with cls.lock:
            if cls.last >= cls.nrcpu:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1
            cls.nrevents += 1

    @classmethod
    def shutdown(cls):
        for client in cls.clients:
            client.wait()
        time.sleep(0.01)
        for client in cls.clients:
            client.stop()
        time.sleep(0.01)


class Runs:

    nrs = 0

    @classmethod
    def banner(cls):
        "hello"
        tme = time.ctime(time.time()).replace("  ", " ")
        txt = "%s %s since %s %s (%s)" % (
            Main.name.upper(),
            Main.version,
            tme,
            Main.level.upper() or "INFO",
            Boot.core()
        )
        print(txt.replace("  ", " "))
        sys.stdout.flush()

    @staticmethod
    def check(opts):
        "check for command line options."
        for arg in sys.argv:
            if not arg.startswith("-"):
                continue
            for opt in opts:
                if opt in arg:
                    return True
        return False

    @staticmethod
    def payload(todo):
        for cmd, example in todo.items():
            for ex in example:
                evt = Message()
                evt.kind = "command"
                evt.text = f"{cmd} {ex}"
                Clients.put(evt)

    @classmethod
    def wrap(cls, function, *args, dofinal=None):
        "restore console."
        import termios
        oldie = None
        try:
            oldie = termios.tcgetattr(sys.stdin.fileno())
        except termios.error:
            pass
        try:
            function(*args)
        except (KeyboardInterrupt, EOFError):
            pass
        except Exception as exc:
            logging.exception(exc)
        if oldie:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, oldie)
        if dofinal:
            final()


def final():
    if not Main.verbose:
        return
    total = Clients.nrevents
    endtime = time.time()
    lap = Time.elapsed(endtime-Time.starttime)
    percall = (endtime-Time.starttime)/total
    print(f"{Object.fmt(Main, skip='otxt,txt')}")
    print(f"cores: {Clients.nrcpu} events: {total}")
    print(f"total: {lap} nrs: {Clients.nrevents - total} call: %.6fs" % percall)
    res = ""
    for client in Clients.clients:
        res += str(client.queue.qsize()) + " "
    print(res.strip())
    print(threading.enumerate())


def main():
    if e(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Runs.check("v"):
        Main.verbose = True
        Runs.banner()
    if Runs.check("t"):
        Main.threaded = True
    Parse.parse(Main, " ".join(sys.argv[1:]))
    if Main.threaded:
        Clients.init(os.cpu_count(), CLI)
    else:
        Clients.init(1, CLI)
    Runs.nrs = Main.index or 1
    thrs = []
    for _x in range(Runs.nrs):
        thrs.append(Thread.launch(Runs.payload, pre))
    for thr in thrs:
        thr.join()
    thrs = []
    for _x in range(Runs.nrs):
        thrs.append(Thread.launch(Runs.payload, examples))
    for thr in thrs:
        thr.join()
    thrs = []
    for _x in range(Runs.nrs):
        thrs.append(Thread.launch(Runs.payload, post))
    for thr in thrs:
        thr.join()
    Clients.shutdown()
    while 1:
        if len(threading.enumerate()) == 1:
            break
        time.sleep(0.01)


examples = {
    "cmd": [""],
    "dis": [""],
    "dpl": ["", "tittle.link"],
    "eml": ["", "root@localhost"],
    "flt": ["", "0"],
    "fnd": ["", "log", "todo"],
    "fie": ["", "log", "todo"],
    "lou": [""],
    "mbx": ["", "~/25-1-2013"],
    "man": ["", "nixt nixtniet@gmail.com Nixt Niet"],
    "nme": ["", "hnrss hn"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "tbl": [""],
    'thr': [""],
    'upt': [""],
    'ver': [""],
}


