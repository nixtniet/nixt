#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import queue
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from nixt.command import Commands
from nixt.configs import Main
from nixt.handler import Console, Event
from nixt.objects import Data, Methods
from nixt.package import Mods
from nixt.persist import Workdir
from nixt.threads import Thread
from nixt.utility import Log, Time, Utils


from nixt import modules as MODS


try:
    import mods as MODS2
except ModuleNotFoundError:
    MODS2 = None


Main.wdr = ".test"


events = queue.Queue()


class CLI(Console):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        if "v" in Main.opts:
            print(text.encode('utf-8', 'replace').decode("utf-8"))


class Clients:

    clients = []
    lock = threading.RLock()
    nrcpu = 1
    last = 0

    @staticmethod
    def add(client):
        Clients.clients.append(client)

    @staticmethod
    def init(nrcpu, cls):
        Clients.nrcpu = nrcpu
        for _x in range(Clients.nrcpu):
            clt = cls()
            clt.start()
            Clients.add(clt)

    @staticmethod
    def put(*args):
        with Clients.lock:
            if Clients.last >= Clients.nrcpu-1:
                Clients.last = 0
            clt = Clients.clients[Clients.last]
            clt.put(*args)
            Clients.last += 1


def consume():
    while True:
        try:
            event = events.get()
            event.wait()
            events.task_done()
        except (KeyboardInterrupt, EOFError):
            os._exit(0)


def payload(todo):
    cli = CLI()
    for cmd, example in todo.items():
        if Main.cmd:
            if cmd not in Utils.spl(Main.cmd):
                continue
        for ex in example:
            evt = Event()
            evt.orig = repr(cli)
            evt.text = f"{cmd} {ex}"
            Commands.command(evt)
            events.put(evt)


def main():
    if "p" not in Main.opts and os.path.exists(Main.wdr):
        shutil.rmtree(Main.wdr)
    parsed = Data()
    Methods.parse(parsed, " ".join(sys.argv[1:]))
    Methods.merge(Main, parsed)
    Workdir.skel()
    Log.level(Main.level)
    Mods.pkg(MODS, MODS2)
    Main.mods = Main.mods or Mods.list()
    Commands.scanner()
    starttime = time.time()
    nrs = Main.index or 1
    for _x in range(nrs):
        payload(pre)
    for _x in range(nrs):
        payload(examples)
    for _x in range(nrs):
        payload(post)
    nrevents = events.qsize()
    Thread.launch(consume)
    try:
        events.join()
    except (KeyboardInterrupt, EOFError):
        pass
    endtime = time.time()
    lap = Time.elapsed(endtime-starttime)
    percall = (endtime-starttime)/nrevents
    nrs = events.qsize()
    if "v" in Main.opts:
        print(f"{Methods.fmt(Main, skip='otxt,txt')}")
        print(f"{nrs} events left.")
        print(f"total: {lap} nrs: {nrevents} call: %.6fs" % percall)


examples = {
    "cmd": [""],
    "dis": [""],
    "dne": ["", "bla"],
    "dpl": ["hnrss title,url", ""],
    "eml": ["", "root@localhost"],
    "fie": ["", "log", "todo"],
    "flt": ["", "0"],
    "fnd": ["", "log", "rss", "config", "todo"],
    "lou": [""],
    "man": ["", "nixt nixtniet@gmail.com Nixt Niet"],
    "mbx": [""],
    "mod": [""],
    "mre": [""],
    "nme": ["", "hnrss hackernews"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "syn": [""],
    "thr": [""],
    "tmr": ["", "22:00 test"],
    "upt": [""],
    "wsd": [""]
}

pre = {
    "cfg": ["", "nick=mekker"],
    "imp": [
        "",
        "testing/opml/feeds.opml",
    ],
    "log": ["", "log test"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test"]
}

post = {
    "dbg": [""],
    "dne": ["", "mekker"],
    "exp": [""],
    "rem": ["", "hnrss"]
}


if __name__ == "__main__":
    main()
