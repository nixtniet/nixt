from nixt import modules as MODS


try:
    import mods as MODS2
except ModuleNotFoundError:
    MODS2 = None


Main.debug = True
Main.wdr = ".test"
Main.user = True


events = queue.Queue()


class CLI(Client):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))


class Clients:

    clients = []
    lock = threading.RLock()
    nrcpu = 1
    last = 0

    @classmethod
    def add(cls, client):
        cls.clients.append(client)

    @classmethod
    def init(cls, nrcpu, client):
        with cls.lock:
            cls.nrcpu = nrcpu
            for _x in range(Clients.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1


def consume():
    while True:
        try:
            event = events.get()
            event.wait()
            events.task_done()
        except (KeyboardInterrupt, EOFError):
            os._exit(0)


def payload(todo):
    for cmd, example in todo.items():
        for ex in example:
            evt = Event()
            evt.kind = "command"
            evt.text = f"{cmd} {ex}"
            #Commands.command(evt)
            Clients.put(evt)
            events.put(evt)


def main():
    Arguments.getargs()
    if "p" not in Main.opts and os.path.exists(Main.wdr):
        shutil.rmtree(Main.wdr)
    Boot.boot()
    if Main.threaded:
        Clients.init(os.cpu_count(), CLI)
    else:
        Clients.init(1, CLI)
    starttime = time.time()
    nrs = Main.index or 1
    thrs = []
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, pre))
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, examples))
    for _x in range(nrs):
        thrs.append(Thread.launch(payload, post))
    for thr in thrs:
        thr.join()
    nrevents = events.qsize()
    Thread.launch(consume)
    try:
        events.join()
    except (KeyboardInterrupt, EOFError):
        pass
    endtime = time.time()
    lap = Time.elapsed(endtime-starttime)
    percall = (endtime-starttime)/nrevents
    nrs = events.qsize()
    if Main.verbose:
        print(f"{Methods.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {Clients.nrcpu} events: {nrs}")
        print(f"total: {lap} nrs: {nrevents} call: %.6fs" % percall)


examples = {
    "cmd": [""],
    "dis": [""],
    "dne": ["", "bla"],
    "dpl": ["hnrss title,url", ""],
    "eml": ["", "root@localhost"],
