"stress test"


import logging
import os
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from nixt.message import Message
from nixt.objects import Method
from nixt.package import Commands, Mods, Parse
from nixt.persist import Workdir
from nixt.utility import Logging, Time, Utils


Workdir.wdr = ".test"
Mods.dir("mods", "mods")
Mods.configure("nixt")
print(Workdir.wdr)

verbose = False


def raw(text):
    if verbose:
        print(text.encode('utf-8', 'replace').decode("utf-8"))
        sys.stdout.flush()


def check(opts):
    "check for command line options."
    for arg in sys.argv:
        if not arg.startswith("-"):
            continue
        for opt in opts:
            if opt in arg:
                return True
    return False


def payload(todo):
    for cmd, example in todo.items():
        for ex in example:
            evt = Message()
            evt.text = f"{cmd} {ex}"
            Commands.command(evt)
            for text in evt.result:
                raw(text)


def main():
    if os.path.exists(Workdir.wdr):
        shutil.rmtree(Workdir.wdr)
    if check("v"):
        verbose = True
    nrs = 1
    for _x in range(nrs):
        payload(pre)
    thrs = []
    for _x in range(nrs):
        payload(examples)
    thrs = []
    for _x in range(nrs):
        payload(post)


examples = {
