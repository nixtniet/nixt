#!/usr/bin/env python3
# This file is placed in the Public Domain.


"fuzzer"


import logging
import os
import queue
import shutil
import sys
import threading
import traceback
import time


sys.path.insert(0, os.getcwd())


from bot.defines import Base, Boot, Buffered, Client, Logging, Main, Message
from bot.defines import Mods, Object, Parse, Thread, Time, Workdir, e


Main.debug = True
Main.name = "fuzzer"
Main.user = True
Main.wdr = ".test"


Workdir.wdr = Main.wdr


class CLI(Buffered):

    def handle(self, event):
        Mods.command(event)

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))
            sys.stdout.flush()


class ClientPool:

    clients = []
    lock = threading.RLock()
    last = 0
    nrevents = 0
    nrcpu = 1

    @classmethod
    def add(cls, client):
        "add a client to the pool."
        cls.clients.append(client)

    @classmethod
    def init(cls, client):
        "initialize pool with nr_cpu clients."
        with cls.lock:
            cls.nrcpu = os.cpu_count()
            for _x in range(cls.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        "put job to the pool."
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1
            cls.nrevents += 1

    @classmethod
    def shutdown(cls):
        for client in cls.clients:
            client.wait()
        time.sleep(0.01)
        for client in cls.clients:
            client.stop()
        time.sleep(0.01)



class Run:

    nrs = 0

    @classmethod
    def banner(cls):
        "hello"
        tme = time.ctime(time.time()).replace("  ", " ")
        txt = "%s %s since %s %s (%s)" % (
            Main.name.upper(),
            Main.version,
            tme,
            Main.level.upper() or "INFO",
            Boot.core()
        )
        print(txt.replace("  ", " "))
        sys.stdout.flush()

    @staticmethod
    def check(opts):
        "check for command line options."
        for arg in sys.argv:
            if not arg.startswith("-"):
                continue
            for opt in opts:
                if opt in arg:
                    return True
        return False

    @staticmethod
    def payload():
        for cmd in Commands.cmds:
            for arg in arguments:
                evt = Message()
                evt.kind = "command"
                evt.text = f"{cmd} {arg}"
                ClientPool.put(evt)

    @classmethod
    def wrap(cls, function, *args, dofinal=None):
        "restore console."
        import termios
        oldie = None
        try:
            oldie = termios.tcgetattr(sys.stdin.fileno())
        except termios.error:
            pass
        try:
            function(*args)
        except (KeyboardInterrupt, EOFError):
            pass
        except Exception as exc:
            logging.exception(exc)
        if oldie:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, oldie)
        if dofinal:
            final()


def final():
    total = len(Commands.cmds) * len(arguments) * Run.nrs
    endtime = time.time()
    lap = Time.elapsed(endtime-Time.starttime)
    if Main.verbose and total:
        percall = (endtime-Time.starttime)/total
        print(f"{Object.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {ClientPool.nrcpu} events: {total}")
        print(f"total: {lap} nrs: {ClientPool.nrevents - total} call: %.6fs" % percall)
        res = ""
        gotcha = False
        for client in ClientPool.clients:
            sze = client.iqueue.qsize()
            if sze:
                gotcha = True
            res += str(sze) + " "
        if gotcha:
            for client in ClientPool.clients:
                try:
                    print(client.iqueue.get_nowait())
                except queue.Empty:
                    pass
        print(threading.enumerate())


def main():
    if e(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Run.check("v"):
        Main.verbose = True
        Run.banner()
    Main.md5 = True
    Parse.parse(Main, " ".join(sys.argv[1:]))
    Boot.configure()
    Boot.scanner()
    ClientPool.init(CLI)
    Run.nrs = Main.index or 1
    thrs = []
    for _x in range(Run.nrs):
        thrs.append(Thread.launch(Run.payload))
    for thr in thrs:
        thr.join()
    ClientPool.shutdown()
    while 1:
        if len(threading.enumerate()) == 1:
            break
        time.sleep(0.01)


arguments = [
             "main",
             "log",
             "rss",
             "config",
             "todo",
             'timers',
             'hnrss title,link',
             "nick=mekker",
             "http://hnrss.org/newest",
             "22:00 test",
             "nixt nixtniet@gmail.com Nixt Niet",
             '10',
             10,
             Base,
             Base()
            ]


if __name__ == "__main__":
    Run.wrap(main, dofinal=final)
