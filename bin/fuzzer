#!/usr/bin/env python3
# This file is placed in the Public Domain.


"fuzzer"


import logging
import os
import queue
import shutil
import sys
import threading
import traceback
import time


sys.path.insert(0, os.getcwd())


from nixt.defines import Object, Boot, Buffered, Client, Commands, Logging
from nixt.defines import Main, Message, Mods, Method, Parse, Task
from nixt.defines import Thread, Time,  Workdir


Main.debug = True
Main.name = "fuzzer"
Workdir.wdr = Main.path = ".test"


class CLI(Buffered):

    def __init__(self):
        Buffered.__init__(self)
        self.register("command", Commands.command)

    def post(self, event):
        event.wait()

    def raw(self, text):
        if Main.verbose:
            print(text.encode('utf-8', 'replace').decode("utf-8"))
            sys.stdout.flush()


class ClientPool:

    clients = []
    lock = threading.RLock()
    last = 0
    nrevents = 0
    nrcpu = 1

    @classmethod
    def add(cls, client):
        "add a client to the pool."
        cls.clients.append(client)

    @classmethod
    def init(cls, client):
        "initialize pool with nr_cpu clients."
        with cls.lock:
            cls.nrcpu = os.cpu_count()
            for _x in range(cls.nrcpu):
                clt = client()
                clt.start()
                cls.add(clt)

    @classmethod
    def put(cls, *args):
        "put job to the pool."
        with cls.lock:
            if cls.last >= cls.nrcpu-1:
                cls.last = 0
            cls.clients[cls.last].put(*args)
            cls.last += 1
            cls.nrevents += 1

    @classmethod
    def shutdown(cls):
        "shutdown"
        for client in cls.clients:
            client.wait()
        time.sleep(0.01)
        for client in cls.clients:
            client.stop()
        time.sleep(0.01)


class Kernel(Boot):

    nrs = 0

    @classmethod
    def banner(cls):
        print(Boot.banner())
        sys.stdout.flush()

    @staticmethod
    def check(opts):
        "check for command line options."
        for arg in sys.argv:
            if not arg.startswith("-"):
                continue
            for opt in opts:
                if opt in arg:
                    return True
        return False

    @staticmethod
    def payload():
        for cmd in Commands.cmds:
            for arg in arguments:
                evt = Message()
                evt.kind = "command"
                evt.text = f"{cmd} {arg}"
                ClientPool.put(evt)

    @classmethod
    def wrap(cls, function, *args, dofinal=None):
        "restore console."
        import termios
        oldie = None
        try:
            oldie = termios.tcgetattr(sys.stdin.fileno())
        except termios.error:
            pass
        try:
            Boot.wrapped(function, *args)
        except (KeyboardInterrupt, EOFError):
            pass
        if oldie:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, oldie)
        if dofinal:
            final()


def final():
    total = len(Commands.cmds) * len(arguments) * Kernel.nrs
    endtime = time.time()
    lap = Time.elapsed(endtime-Time.starttime)
    if Main.verbose and total:
        percall = (endtime-Time.starttime)/total
        print(f"{Method.fmt(Main, skip='otxt,txt')}")
        print(f"cores: {ClientPool.nrcpu} events: {total}")
        print(f"total: {lap} nrs: {ClientPool.nrevents - total} call: %.6fs" % percall)
        res = ""
        gotcha = False
        for client in ClientPool.clients:
            sze = client.queue.qsize()
            if sze:
                gotcha = True
            res += str(sze) + " "
        print(res)
        if gotcha:
            for client in ClientPool.clients:
                try:
                    print(client.queue.get_nowait())
                except queue.Empty:
                    pass
        print(threading.enumerate())


def main():
    if os.path.exists(Main.wdr):
        shutil.rmtree(Main.wdr)
    if Kernel.check("v"):
        Main.verbose = True
        Kernel.banner()
    Main.md5 = True
    Parse.parse(Main, " ".join(sys.argv[1:]))
    Kernel.configure()
    Mods.dir("mods", "mods")
    Mods.scanner()
    ClientPool.init(CLI)
    Kernel.nrs = Main.index or 1
    thrs = []
    for _x in range(Kernel.nrs):
        thrs.append(Thread.launch(Kernel.payload))
    for thr in thrs:
        thr.join()
    ClientPool.shutdown()
    while 1:
        if len(threading.enumerate()) == 1:
            break
        time.sleep(0.01)



arguments = [
             "main",
             "log",
             "rss",
             "config",
             "todo",
             'timers',
             'hnrss title,link',
             "nick=mekker",
             "http://hnrss.org/newest",
             "22:00 test",
             "nixt nixtniet@gmail.com Nixt Niet",
             '10',
             10,
             Object,
             Object()
            ]


if __name__ == "__main__":
    Kernel.wrap(main, dofinal=final)
