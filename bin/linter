#!/usr/bin/env python3
# This file is placed in the Public DOmain.


"run linters"


import os
import sys


NAME = "nixt"


SKIP = ["--", "Your", "All"]


def doskip(line):
    for x in SKIP:
        if x in line:
            return True
    return False     


def popen(txt):
    for line in os.popen(txt).readlines():
        line = line.strip()
        if not line or doskip(line):
            continue
        print(line.rstrip())
        sys.stdout.flush()


popen(f"ruff check {NAME} bin mods testing")
popen(f"pylint {NAME} bin mods testing")
popen(f"flake8 {NAME} bin mods testing")


