#!/usr/bin/env python3
# This file is placed in the Public Domain.


"main program"


import os
import sys


sys.path.insert(0, os.getcwd())


from nixt.command import Commands
from nixt.defines import Main
from nixt.handler import Console, Event
from nixt.package import Mods
from nixt.runtime import Runtime


class Line(Console):

    def __init__(self):
        super().__init__()
        self.register("command", Commands.command)

    def raw(self, text):
        "write to console."
        print(text.encode('utf-8', 'replace').decode("utf-8"))


def docmd(text):
    "parse text for command and run it."
    cli = Line()
    cli.start()
    for txt in text.split(" ! "):
        evt = Event()
        evt.orig = repr(cli)
        evt.text = txt
        evt.kind = "command"
        Commands.command(evt)
        evt.wait()
    return evt


def cmd(event):
    "list available commands."
    event.reply(",".join(sorted(Commands.names.keys() or Commands.cmds.keys())))


def ver(event):
    "show verson."
    event.reply(f"{Main.name.upper()} {Main.version}")


def main():
    "main"
    Mods.add("mods", "mods")
    Runtime.scanner(Main)
    Commands.add(cmd, ver)
    docmd(" ".join(sys.argv[1:]))


if __name__ == "__main__":
    main()
