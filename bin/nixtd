#!/usr/bin/env python3
# This file is placed in the Public Domain.


"daemon"


import os
import sys


sys.path.insert(0, os.getcwd())


from nixt.defines import Kernel, Main


def daemon():
    Main.sets.default = "irc,rss"
    Kernel.daemon(Main.verbose, Main.nochdir)
    Kernel.privileges()
    Kernel.configure()
    Kernel.pid()
    Kernel.init()
    Kernel.forever()


Kernel.wrap(daemon)
